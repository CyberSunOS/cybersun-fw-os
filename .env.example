# ============================================
# TWELVE-FACTOR CONFIG TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# See: docs/TWELVE_FACTOR_COMPLIANCE.md

# ============================================
# I. CODEBASE
# ============================================
# No environment variables needed for codebase

# ============================================
# II. DEPENDENCIES
# ============================================
# No environment variables needed for dependencies

# ============================================
# III. CONFIG
# ============================================

# Environment
NODE_ENV=development
# Options: development, staging, production

# ============================================
# IV. BACKING SERVICES
# ============================================

# Database (Primary)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# Format: postgresql://user:password@host:port/database
# Example: postgresql://postgres:secret@localhost:5432/myapp

# Database (Read Replica - Optional)
# DATABASE_READ_URL=postgresql://user:password@replica-host:5432/dbname

# Cache (Redis)
REDIS_URL=redis://localhost:6379
# Format: redis://[:password@]host:port[/db-number]
# Example: redis://:secret@localhost:6379/0

# Authentication
AUTH_SECRET=your-secret-key-here-min-32-chars
# Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000
# Your app's URL (used for OAuth callbacks)

# Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com

# Storage (S3-compatible)
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_REGION=us-east-1
STORAGE_BUCKET=your-bucket-name
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key

# Payment (Stripe)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# External APIs
API_KEY=your-api-key
API_URL=https://api.example.com
API_SECRET=your-api-secret

# ============================================
# V. BUILD, RELEASE, RUN
# ============================================
# Build-time variables (if needed)
# NEXT_PUBLIC_API_URL=https://api.example.com

# ============================================
# VI. PROCESSES
# ============================================
# Session storage is handled by backing services (Redis/Database)
# No additional environment variables needed

# ============================================
# VII. PORT BINDING
# ============================================

# Port
PORT=3000
# The port your application will bind to

# ============================================
# VIII. CONCURRENCY
# ============================================

# Worker Configuration
WORKER_CONCURRENCY=5
# Number of concurrent workers for background jobs

# Database Connection Pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
# Min and max database connections

# ============================================
# IX. DISPOSABILITY
# ============================================

# Graceful Shutdown
SHUTDOWN_TIMEOUT=30000
# Timeout in milliseconds for graceful shutdown

# ============================================
# X. DEV/PROD PARITY
# ============================================
# Use same backing services in all environments
# Development should mirror production as closely as possible

# ============================================
# XI. LOGS
# ============================================

# Logging
LOG_LEVEL=info
# Options: debug, info, warn, error
LOG_FORMAT=json
# Options: json, pretty

# ============================================
# XII. ADMIN PROCESSES
# ============================================
# Admin processes use the same environment variables
# No additional configuration needed

# ============================================
# ADDITIONAL CONFIGURATION
# ============================================

# Feature Flags
FEATURE_NEW_UI=false
FEATURE_BETA_ACCESS=false

# Rate Limiting
RATE_LIMIT_WINDOW=900000
# 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window

# CORS
CORS_ORIGIN=http://localhost:3000
# Comma-separated list of allowed origins

# Security
BCRYPT_ROUNDS=10
# Number of bcrypt rounds for password hashing

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real values
# 2. Use strong, unique secrets for each environment
# 3. Rotate secrets regularly
# 4. Use a secrets manager in production (Vault, AWS Secrets Manager, etc.)
# 5. Document any new environment variables you add

